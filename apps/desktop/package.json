{
  "name": "@cloak/desktop",
  "version": "1.0.0",
  "description": "Capture-aware teleprompter overlay",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --inspect",
    "test": "node --test test/*.test.js",
    "coverage": "c8 --reporter=text --reporter=html --include='lib/**/*.js' --include='server/index.js' node --test test/*.test.js",
    "dist": "electron-builder --config.npmRebuild=false",
    "dist:mac": "electron-builder --mac --config.npmRebuild=false",
    "dist:win": "electron-builder --win --config.npmRebuild=false",
    "build:dmg": "bash ../../scripts/build-mac-dmg.sh",
    "install:local": "bash ../../scripts/install-local-mac-app.sh"
  },
  "dependencies": {
    "@cloak/shared": "*",
    "electron-updater": "^6.3.9",
    "mongodb": "^7.2.0",
    "qrcode": "^1.5.3",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "7zip-bin": "^5.2.0",
    "c8": "^11.0.0",
    "electron": "30.5.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.lalrishav.cloak",
    "productName": "Cloak",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "windows/**/*",
      "lib/**/*",
      "server/**/*",
      "assets/**/*",
      "!**/*.test.js",
      "!_test-openai.js"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg"
      ],
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "icon": "assets/icon.png"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://downloads.example.com/cloak"
      }
    ]
  }
}
