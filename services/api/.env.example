# Cue backend API — copy to .env and adjust. Never commit .env.
PORT=8787
HOST=0.0.0.0

# Local MongoDB. This is a SEPARATE database from the desktop app's local "cue" db.
CUE_CLOUD_MONGO_URI=mongodb://127.0.0.1:27017
CUE_CLOUD_MONGO_DB=cue_cloud

# Public base URL used to build the downloadUrl in the boot response.
CUE_DOWNLOAD_BASE_URL=http://localhost:8787

# Admin dashboard login — simple signed-cookie auth (v1).
CUE_ADMIN_USER=admin
CUE_ADMIN_PASS=change-me-locally
# Used to sign the session cookie. Make this long and random for any real deploy.
CUE_SESSION_SECRET=dev-only-secret-change-me-to-a-long-random-string

# Allowed CORS origin(s) for the admin dashboard (Vite dev server). Comma-separate.
CUE_ADMIN_ORIGIN=http://localhost:5173

# AI proxy keys. These live ONLY here — the desktop app fetches AI capability
# through /v1/ai/* so the shipped binary contains no keys. Leave blank to
# disable the proxy (the desktop falls back to its own local env vars).
OPENAI_API_KEY=
DEEPGRAM_API_KEY=
