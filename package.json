{
  "name": "cloak",
  "version": "1.0.1",
  "private": true,
  "description": "Cloak — capture-aware teleprompter (monorepo: desktop app, admin API, admin dashboard)",
  "workspaces": [
    "packages/*",
    "services/*",
    "apps/*"
  ],
  "scripts": {
    "dev:desktop": "npm run start -w @cloak/desktop",
    "dev:api": "npm run dev -w @cloak/api",
    "dev:admin": "npm run dev -w @cloak/admin-web",
    "dev": "concurrently -n api,admin -c blue,magenta \"npm:dev:api\" \"npm:dev:admin\"",
    "dist:win": "npm run dist:win -w @cloak/desktop",
    "dist:mac": "npm run dist:mac -w @cloak/desktop",
    "build:dmg": "bash scripts/build-mac-dmg.sh",
    "install:local": "bash scripts/install-local-mac-app.sh",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "7zip-bin": "^5.2.0",
    "concurrently": "^9.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
