{
  "name": "cue",
  "version": "1.0.0",
  "private": true,
  "description": "Cue — capture-aware teleprompter (monorepo: desktop app, admin API, admin dashboard)",
  "workspaces": [
    "packages/*",
    "services/*",
    "apps/*"
  ],
  "scripts": {
    "dev:desktop": "npm run start -w @cue/desktop",
    "dev:api": "npm run dev -w @cue/api",
    "dev:admin": "npm run dev -w @cue/admin-web",
    "dev": "concurrently -n api,admin -c blue,magenta \"npm:dev:api\" \"npm:dev:admin\"",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "7zip-bin": "^5.2.0",
    "concurrently": "^9.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
